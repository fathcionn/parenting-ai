# TalkWise Environment Variables Template
# Copy this file as .env.local and fill in your actual values
# WARNING: Never commit .env.local to version control!

# ==========================================
# Firebase Configuration
# ==========================================
# Get these from Firebase Console > Project Settings

EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id-here
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# ==========================================
# AI Services
# ==========================================

# OpenAI API Key (for Whisper speech-to-text)
# Get from https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=sk-your_openai_key_here

# HuggingFace API Key (for free NLP analysis)
# Get from https://huggingface.co/settings/tokens
EXPO_PUBLIC_HUGGINGFACE_API_KEY=hf_your_huggingface_key_here

# ==========================================
# App Configuration
# ==========================================

# App environment: development, staging, production
EXPO_PUBLIC_ENV=development

# Public backend URL for native Android/iOS builds
EXPO_PUBLIC_API_BASE_URL=https://your-railway-url.up.railway.app

# Gemini backend key, used by server.js only
GEMINI_API_KEY=your_gemini_api_key

# Enable debug logging
EXPO_PUBLIC_DEBUG=false

# ==========================================
# Notes:
# - All EXPO_PUBLIC_* variables are embedded in the app binary
# - Other variables are only available during build time
# - For sensitive data, use Firebase Cloud Functions
# ==========================================
