# TalkWise Environment Variables
# Copy this file to .env and fill in your values

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# Public backend URL for native Android/iOS builds
EXPO_PUBLIC_API_BASE_URL=https://your-railway-url.up.railway.app

# Gemini backend key, used by server.js only
GEMINI_API_KEY=your_gemini_api_key

# OpenAI (used in Cloud Functions, not in the app directly)
# Set via: firebase functions:config:set openai.key="sk-..."
# OPENAI_API_KEY=sk-...

# Google Cloud Speech-to-Text
# Automatically uses Firebase service account credentials
