{
  "expo": {
    "name": "TalkWise",
    "slug": "talkwise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "talkwise",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.talkwise.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "TalkWise needs microphone access to record and analyse your parenting sessions.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "com.talkwise.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "RECORD_AUDIO",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logo.png",
      "template": "./web/index.html"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "TalkWise needs access to your microphone to record interactions."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
